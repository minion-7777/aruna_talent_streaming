# Local dev (npm run dev on host) — requires: docker compose up postgres redis -d
PORT=3001
HOSTNAME=api-local
DATABASE_URL=postgres://aruna:aruna@localhost:5432/aruna
REDIS_URL=redis://localhost:6379
INGEST_NODES=ingest-1,ingest-2
RTMP_PORT=1935
HLS_BASE_URL=http://localhost:8080/hls
PUBLIC_RTMP_HOST=localhost
PUBLIC_RTMP_PORTS=19351,19352
INTERNAL_API_KEY=dev-internal-key

# Docker Compose overrides DATABASE_URL/REDIS_URL to postgres/redis hostnames automatically.
